{
  "server": {
    "base_url": "http://localhost:11434/v1",
    "api_key": "ollama",
    "request_timeout_seconds": 300
  },
  "agents": {
    "planner": {
      "model": "devstral-small-2:24b",
      "prompt": "agents/planner.md",
      "temperature": 0.3,
      "tools": false,
      "schema": "plan"
    },
    "coder": {
      "model": "devstral-small-2:24b",
      "prompt": "agents/coder.md",
      "temperature": 0.2,
      "tools": true,
      "max_tool_rounds": 25
    },
    "reviewer": {
      "model": "devstral-small-2:24b",
      "prompt": "agents/reviewer.md",
      "temperature": 0.1,
      "tools": false,
      "schema": "review"
    },
    "tester": {
      "model": "devstral-small-2:24b",
      "prompt": "agents/tester.md",
      "temperature": 0.2,
      "tools": true,
      "max_tool_rounds": 25
    }
  },
  "pipeline": {
    "max_review_rounds": 2,
    "max_fix_rounds": 2,
    "command_timeout_seconds": 240
  }
}
